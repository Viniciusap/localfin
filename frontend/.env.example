# API URL — leave empty to use Vite proxy (recommended for development)
# Set to the backend URL only when serving frontend separately (e.g. production)
VITE_API_URL=

# Proxy target — only used when VITE_API_URL is empty
# Change the port here if you changed PORT in backend/.env
VITE_API_PROXY_TARGET=http://localhost:3333

# Locale and currency for number/date formatting
# Examples: en-US / USD  |  pt-BR / BRL  |  de-DE / EUR
VITE_LOCALE=pt-BR
VITE_CURRENCY=BRL
